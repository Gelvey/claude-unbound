# NVIDIA NIM Config
NVIDIA_NIM_API_KEY=""


# OpenRouter Config
OPENROUTER_API_KEY=""


# OpenRouter Data Policy (per-request provider.data_collection injection)
# - OPENROUTER_DATA_COLLECTION: the policy value used for every OpenRouter call
#   by default. 'deny' enforces Zero Data Retention (ZDR); 'allow' permits the
#   upstream provider to retain data.
# - OPENROUTER_FREE_DATA_COLLECTION: the policy value used when the downstream
#   model id is in OPENROUTER_FREE_MODEL_IDS. Most free endpoints require
#   'allow' to be routable.
# - OPENROUTER_FREE_MODEL_IDS: comma-separated EXACT OpenRouter model ids that
#   get the free policy. Empty = no overrides. The gateway always merges this
#   into the request body after the client's extra_body, so a client cannot
#   override the operator's policy.
# See https://openrouter.ai/settings/privacy for account-level controls.
OPENROUTER_DATA_COLLECTION="deny"
OPENROUTER_FREE_DATA_COLLECTION="allow"
OPENROUTER_FREE_MODEL_IDS=""


# Mistral La Plateforme Config (Experiment plan free tier – rate limits; OpenAI-compatible at api.mistral.ai/v1)
MISTRAL_API_KEY=""


# Mistral Codestral (separate key from La Plateforme; OpenAI-compatible at codestral.mistral.ai/v1)
CODESTRAL_API_KEY=""


# DeepSeek Config (uses native Anthropic Messages at api.deepseek.com/anthropic)
DEEPSEEK_API_KEY=""


# Kimi Config (Anthropic-compatible Messages at api.moonshot.ai/anthropic/v1)
KIMI_API_KEY=""


# Wafer Config (uses native Anthropic Messages at pass.wafer.ai/v1/messages)
WAFER_API_KEY=""


# OpenCode Zen (opencode.ai/zen/v1) and OpenCode Go (opencode.ai/zen/go/v1) share OPENCODE_API_KEY
OPENCODE_API_KEY=""


# Z.ai Config (Anthropic-compatible Messages at api.z.ai/api/anthropic/v1)
ZAI_API_KEY=""


# Fireworks AI Config (Anthropic-compatible Messages at api.fireworks.ai/inference/v1)
FIREWORKS_API_KEY=""


# Gemini / Google AI Studio (OpenAI-compatible Chat Completions; see https://ai.google.dev/gemini-api/docs/openai)
GEMINI_API_KEY=""


# Groq Cloud (OpenAI-compatible Chat Completions; see https://console.groq.com/docs/openai)
GROQ_API_KEY=""


# Cerebras Inference (OpenAI-compatible Chat Completions; see https://inference-docs.cerebras.ai/resources/openai)
CEREBRAS_API_KEY=""


# Cloudflare Workers AI (OpenAI-compatible Chat Completions under ai/v1; account ID in URL path).
# Token: https://dash.cloudflare.com/profile/api-tokens (Workers AI:Edit or Workers AI:Read scope).
# Account ID: Cloudflare dashboard right sidebar, or via the Cloudflare API.
# Free tier: 10,000 neurons/day reset at 00:00 UTC. See https://developers.cloudflare.com/workers-ai/.
CLOUDFLARE_AI_API_KEY=""
CLOUDFLARE_AI_ACCOUNT_ID=""
# Optional full URL override (proxies / mocks / self-hosted gateways). Empty falls back to
# https://api.cloudflare.com/client/v4/accounts/<CLOUDFLARE_AI_ACCOUNT_ID>/ai/v1.
CLOUDFLARE_AI_BASE_URL=""


# LM Studio Config (local provider, no API key required)
LM_STUDIO_BASE_URL="http://localhost:1234/v1"


# Llama.cpp Config (local provider, no API key required)
LLAMACPP_BASE_URL="http://localhost:8080/v1"


# Ollama Config (local provider, no API key required)
OLLAMA_BASE_URL="http://localhost:11434"


# Freebuff2API Config (local provider, no API key required)
# Set FREEBUFF_ENABLED=true to activate; credentials are managed by Freebuff2API.
# FREEBUFF_BASE_URL must include /v1 because the provider uses the OpenAI SDK.
FREEBUFF_ENABLED=false
FREEBUFF_BASE_URL="http://127.0.0.1:8080/v1"
FREEBUFF_CREDENTIALS_PATH=""
FREEBUFF_PROXY=""


# Graphify integration (optional, self-hosted knowledge-graph MCP server).
# Graphify runs as a local Python subprocess in an isolated venv — no Docker.
# It is disabled by default; enable it from Admin UI -> Graphify.
GRAPHIFY_ENABLED=false
# Port for the local Graphify MCP HTTP server. The default 7120 is fixed so a
# restarted fcc-server can adopt the still-running graphify on that port and so
# Claude Code's cached mcpServers entry keeps pointing at it across restarts.
# Set 0 only to pick a free port automatically (breaks cross-restart adoption).
GRAPHIFY_SERVER_PORT=7120
# Optional: explicit Python interpreter to run graphify.serve. Leave empty to
# use the main venv if graphifyy is installed, else the isolated ~/.fcc/graphify
# venv created by the Setup button.
GRAPHIFY_PYTHON_PATH=""
# Optional bearer-token auth for the localhost MCP HTTP endpoint. This is NOT a
# cloud API key — Graphify is self-hosted and local-first. Leave empty for no
# auth on the loopback (127.0.0.1) server.
GRAPHIFY_API_KEY=""
# Run the Graphify MCP HTTP server in --stateless mode (default true). Stateless
# mode makes each MCP request independent and removes the mcp-session-id
# header requirement, which is the recommended setting for Claude Code's MCP
# client (stateful mode returns HTTP 400 'Missing session ID' for any
# subsequent call without the rotating per-response session id and surfaces
# as a generic 'Unable to connect' tool error). Set false only if a tool
# genuinely needs server-side request-scoped state.
GRAPHIFY_STATELESS=true
# Optional LLM backend for the semantic extraction pass (graphify extract) over
# docs/PDFs/images and community naming. One of: cloudflare|gemini|deepseek|kimi|
# openai|claude|ollama|azure. 'cloudflare' reuses CLOUDFLARE_AI_API_KEY +
# CLOUDFLARE_AI_ACCOUNT_ID (set on the Providers tab) via the OpenAI-compatible
# Workers AI endpoint; gemini/deepseek/kimi likewise reuse their provider key when
# GRAPHIFY_LLM_API_KEY is empty. Leave empty (or set GRAPHIFY_CODE_ONLY=true) for no
# LLM. Use 'ollama' for a fully-local, no-API-key setup
# (also set OLLAMA_BASE_URL, e.g. http://127.0.0.1:11434).
GRAPHIFY_LLM_BACKEND=""
# API key for GRAPHIFY_LLM_BACKEND, injected into the extractor subprocess as
# the backend's env var (ANTHROPIC_API_KEY, OPENAI_API_KEY, GEMINI_API_KEY,
# DEEPSEEK_API_KEY, MOONSHOT_API_KEY, OLLAMA_API_KEY, AZURE_OPENAI_API_KEY).
# Optional for cloudflare/gemini/deepseek/kimi (falls back to the provider key).
# Required for openai/claude/azure. Ignored when GRAPHIFY_LLM_BACKEND is empty.
# Ollama accepts any non-empty value.
GRAPHIFY_LLM_API_KEY=""
# Model id passed to graphify as --model. For 'cloudflare' use a Workers AI model
# id (e.g. @cf/meta/llama-3.3-70b-instruct-fp8-fast); use a vision-capable model
# (e.g. @cf/meta/llama-3.2-90b-vision-instruct) when the corpus has images.
GRAPHIFY_LLM_MODEL=""
# Index code only via local AST parsing (no LLM API key); skip docs/PDFs/images.
GRAPHIFY_CODE_ONLY=false
GRAPHIFY_AUTO_INDEX_ON_START=false
GRAPHIFY_AUTO_REINDEX=false
GRAPHIFY_MAX_PROJECT_BYTES=10737418240


# All Claude model requests are mapped to these models, plain model is fallback
# Format: provider_type/model/name
# Valid providers: "nvidia_nim" | "open_router" | "gemini" | "deepseek" | "mistral" | "mistral_codestral" | "opencode" | "opencode_go" | "wafer" | "kimi" | "cerebras" | "groq" | "fireworks" | "zai" | "lmstudio" | "llamacpp" | "ollama" | "freebuff"
MODEL_OPUS=
MODEL_SONNET=
# Use the free DeepSeek V4 Pro model for Claude Haiku requests via Freebuff2API.
MODEL_HAIKU="freebuff/deepseek/deepseek-v4-pro"
MODEL="nvidia_nim/nvidia/nemotron-3-super-120b-a12b"


# Optional live smoke model overrides. Provider smoke runs once per configured
# provider even when MODEL/MODEL_* route to a different provider.
FCC_SMOKE_MODEL_NVIDIA_NIM=
FCC_SMOKE_MODEL_OPEN_ROUTER=
FCC_SMOKE_MODEL_MISTRAL=
FCC_SMOKE_MODEL_MISTRAL_CODESTRAL=
FCC_SMOKE_MODEL_DEEPSEEK=
FCC_SMOKE_MODEL_LMSTUDIO=
FCC_SMOKE_MODEL_LLAMACPP=
FCC_SMOKE_MODEL_OLLAMA=
FCC_SMOKE_MODEL_KIMI=
FCC_SMOKE_MODEL_WAFER=
FCC_SMOKE_MODEL_OPENCODE=
FCC_SMOKE_MODEL_OPENCODE_GO=
FCC_SMOKE_MODEL_ZAI=
FCC_SMOKE_MODEL_FIREWORKS=
FCC_SMOKE_MODEL_GEMINI=
FCC_SMOKE_MODEL_GROQ=
FCC_SMOKE_MODEL_CEREBRAS=
FCC_SMOKE_MODEL_CLOUDFLARE_AI=
FCC_SMOKE_MODEL_FREEBUFF=
FCC_SMOKE_NIM_MODELS=
FCC_SMOKE_NIM_EXTRA_MODELS=
FCC_SMOKE_OPENROUTER_FREE_MODELS=
FCC_SMOKE_OPENROUTER_FREE_EXTRA_MODELS=


# Thinking output
# Per-Claude-model switches for provider reasoning requests and Claude thinking blocks.
# Blank per-model switches inherit ENABLE_MODEL_THINKING.
ENABLE_OPUS_THINKING=
ENABLE_SONNET_THINKING=
ENABLE_HAIKU_THINKING=
ENABLE_MODEL_THINKING=true


# CLI permission bypass
CODEX_DANGEROUSLY_BYPASS_APPROVALS=true


# Provider config
# Per-provider proxy support: http and socks5, example: "http://username:password@host:port"
NVIDIA_NIM_PROXY=""
OPENROUTER_PROXY=""
MISTRAL_PROXY=""
CODESTRAL_PROXY=""
LMSTUDIO_PROXY=""
LLAMACPP_PROXY=""
KIMI_PROXY=""
WAFER_PROXY=""
OPENCODE_PROXY=""
OPENCODE_GO_PROXY=""
ZAI_PROXY=""
FIREWORKS_PROXY=""
GEMINI_PROXY=""
GROQ_PROXY=""
CEREBRAS_PROXY=""
CLOUDFLARE_AI_PROXY=""
FREEBUFF_PROXY=""


# Proactive provider rate limiting: at most PROVIDER_RATE_LIMIT requests per
# PROVIDER_RATE_WINDOW seconds across all requests to a provider.
# Set PROVIDER_RATE_LIMIT=0 to disable the proactive window (recommended unless
# your provider enforces a strict request quota); reactive 429/5xx backoff and
# PROVIDER_MAX_CONCURRENCY still protect the upstream.
PROVIDER_RATE_LIMIT=0
PROVIDER_RATE_WINDOW=60
PROVIDER_MAX_CONCURRENCY=5


# HTTP client timeouts (seconds) for provider API requests
HTTP_READ_TIMEOUT=300
HTTP_WRITE_TIMEOUT=60
HTTP_CONNECT_TIMEOUT=60

# Opt-in HTTP/2 for provider HTTP clients (header compression + multiplexing).
# Off by default: some OpenAI-compatible upstreams misbehave over h2.
PROVIDER_HTTP2=false

# Forward the client's `anthropic-beta` header to providers with native
# Anthropic Messages endpoints (keeps beta features like fine-grained tool
# streaming enabled end-to-end). Disable if an Anthropic-compatible upstream
# rejects unknown beta tokens.
FORWARD_ANTHROPIC_BETA=true

# Custom modules: load third-party extensions from FCC_MODULES_DIR at startup.
# FCC_MODULES_ENABLED=false disables discovery entirely; FCC_MODULES_DIR defaults
# to ~/.fcc/modules/. FCC_MODULES_STRICT=true makes any module startup hook
# failure fatal (default false: log the error and continue starting).
FCC_MODULES_ENABLED=true
FCC_MODULES_DIR=
FCC_MODULES_STRICT=false

# Comma-separated provider ids that receive a stable `prompt_cache_key` on
# /chat/completions requests (prompt-cache affinity routing). Empty = only
# providers that opt in via code. Example: "nvidia_nim,groq"
PROMPT_CACHE_KEY_PROVIDERS=""

# Multiplier applied to /v1/messages/count_tokens responses. The local
# tiktoken (cl100k) estimate undercounts vs Anthropic's tokenizer, so Claude
# Code auto-compaction fires too late without correction. Set 1.0 to disable.
TOKEN_COUNT_MULTIPLIER=1.15

# Long-context fallback routing: when BOTH are set, chat requests whose
# estimated input tokens exceed the threshold are rerouted to this
# provider/model ref (pick one with a large context window). Prevents
# sub-agent failures on small-context models (e.g. Cloudflare 24k limits).
# Example: LONG_CONTEXT_MODEL="open_router/qwen/qwen3-coder:free"
#          LONG_CONTEXT_THRESHOLD_TOKENS=20000
LONG_CONTEXT_MODEL=
LONG_CONTEXT_THRESHOLD_TOKENS=0


# Optional server API key (Anthropic-style)
ANTHROPIC_AUTH_TOKEN="freecc"


# Open /admin in the default browser when fcc-server becomes healthy (default off to avoid stealing focus on every launch; set 1/true/yes to enable)
FCC_OPEN_BROWSER=false


# Messaging Platform: "telegram" | "discord" | "none"
MESSAGING_PLATFORM="discord"
MESSAGING_RATE_LIMIT=1
MESSAGING_RATE_WINDOW=1


# Voice Note Transcription
VOICE_NOTE_ENABLED=false
# WHISPER_DEVICE: "cpu" | "cuda" | "nvidia_nim"
# - "cpu"/"cuda": Hugging Face transformers Whisper (offline, free; install with: uv sync --extra voice_local)
# - "nvidia_nim": NVIDIA NIM Whisper via Riva gRPC (requires NVIDIA_NIM_API_KEY; install with: uv sync --extra voice)
# (Independent of MODEL=nvidia_nim/...: that selects the *chat* provider; this selects voice STT only.)
WHISPER_DEVICE="nvidia_nim"
# WHISPER_MODEL:
# - For cpu/cuda: Hugging Face ID or short name (tiny, base, small, medium, large-v2, large-v3, large-v3-turbo)
# - For nvidia_nim: NVIDIA NIM model (e.g., "nvidia/parakeet-ctc-1.1b-asr", "openai/whisper-large-v3")
# - For nvidia_nim, default to "openai/whisper-large-v3" for best performance
WHISPER_MODEL="openai/whisper-large-v3"
HF_TOKEN=""


# Telegram Config
TELEGRAM_BOT_TOKEN=""
ALLOWED_TELEGRAM_USER_ID=""


# Discord Config
DISCORD_BOT_TOKEN=""
ALLOWED_DISCORD_CHANNELS=""


# Agent Config
ALLOWED_DIR=""

FAST_PREFIX_DETECTION=true
ENABLE_NETWORK_PROBE_MOCK=true
ENABLE_TITLE_GENERATION_SKIP=true
ENABLE_SUGGESTION_MODE_SKIP=true
ENABLE_FILEPATH_EXTRACTION_MOCK=true

# Append a short concise-output directive to every request's system prompt.
# It is appended after existing system content (a constant suffix), so provider
# prefix caches keep matching. Output tokens cost ~5x input on most providers.
# Override the directive text with CONCISE_OUTPUT_DIRECTIVE.
CONCISE_OUTPUT=true
CONCISE_OUTPUT_DIRECTIVE=""


# Local Anthropic web_search / web_fetch handling (performs outbound HTTP; on by default)
ENABLE_WEB_SERVER_TOOLS=true
WEB_FETCH_ALLOWED_SCHEMES=http,https
WEB_FETCH_ALLOW_PRIVATE_NETWORKS=false


# Minimum log level for the JSON log sink (TRACE, DEBUG, INFO, WARNING, ERROR, CRITICAL).
LOG_LEVEL=INFO

# Structured TRACE logs: lines with `"trace": true` merge ingress/routing/cli/provider/egress
# stages. By default long conversation text inside snapshots is truncated to short previews;
# set TRACE_FULL_PAYLOADS=true to log conversation text verbatim. Values under keys named
# like ``api_key`` / ``authorization`` are redacted. Raw transport payloads still require
# the LOG_RAW_* toggles below.
TRACE_FULL_PAYLOADS=false
#
# Verbose diagnostics (avoid logging raw prompts / SSE bodies in production)
DEBUG_PLATFORM_EDITS=false
DEBUG_SUBAGENT_STACK=false
# When true, also allows DEBUG-level httpx/httpcore/telegram log noise (not just payload logging).
LOG_RAW_API_PAYLOADS=false
LOG_RAW_SSE_EVENTS=false
# When true, log full exception text and tracebacks for unhandled errors (may leak request-derived data).
LOG_API_ERROR_TRACEBACKS=false
# When true, log message/transcription text previews in messaging adapters only (handler ingress always TRACEs verbatim text separately).
LOG_RAW_MESSAGING_CONTENT=false
# When true, log full Claude CLI stderr, non-JSON stdout lines, and parser error text.
LOG_RAW_CLI_DIAGNOSTICS=false
# When true, log full exception and CLI error message strings in messaging (may leak user content).
LOG_MESSAGING_ERROR_DETAILS=false
